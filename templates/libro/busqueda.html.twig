{% extends "base.html.twig" %}
{% block body %}
<div class="container my-5">
    <h1 class="mb-4">Buscar libros</h1>

    <form method="get" action="{{ path('libro_buscar') }}" class="row g-3 mb-4">
        <div class="col-md-4">
            <label for="titulo" class="form-label">Título</label>
            <input type="text" id="titulo" name="titulo" class="form-control" placeholder="Ej: Harry Potter">
        </div>

        <div class="col-md-4">
            <label for="unidades" class="form-label">Unidades mínimas vendidas</label>
            <input type="number" id="unidades" name="unidades" class="form-control" placeholder="Ej: 100">
        </div>

        <div class="col-md-4">
            <label for="autor" class="form-label">Autor</label>
            <input type="text" id="autor" name="autor" class="form-control" placeholder="Ej: J.K. Rowling">
        </div>

        <div class="col-12">
            <button type="submit" class="btn btn-primary mt-2">Buscar</button>
        </div>
    </form>

    <h2 class="mb-3">Resultados:</h2>
    
    {% if libros|length > 0 %}
        <ol class="list-group">
            {% for libro in libros %}
                <li class="list-group-item">
                    <div class="fw-bold">{{ libro.titulo }}</div>
                    Unidades vendidas: {{ libro.unidadesVendidas }}<br>
                    Autor(es):
                    {% if libro.autores|length > 0 %}
                        {% set nombres = [] %}
                        {% for a in libro.autores %}
                            {% set nombres = nombres | merge([a.nombre]) %}
                        {% endfor %}
                        {{ nombres | join(', ') }}
                    {% else %}
                        Autor anónimo
                    {% endif %}
                </li>
            {% endfor %}
        </ol>
    {% else %}
        <div class="alert alert-warning">No se encontraron libros</div>
    {% endif %}
</div>
{% endblock %}